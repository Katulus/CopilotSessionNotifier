<Window x:Class="CopilotNotifier.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copilot Notifier Settings"
        Width="400" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource SettingsBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="⚙ Settings"
                   Foreground="{DynamicResource SettingsHeaderForeground}"
                   FontSize="18"
                   FontWeight="SemiBold"/>

        <!-- Notifications section -->
        <TextBlock Grid.Row="2" Text="Notifications" Foreground="{DynamicResource SettingsSectionForeground}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="3" Margin="0,0,0,4">
            <CheckBox x:Name="ChkWaitingInput" Content="Notify on waiting for input" Foreground="{DynamicResource SettingsTextForeground}" Margin="0,4"/>
            <CheckBox x:Name="ChkSessionComplete" Content="Notify on session complete" Foreground="{DynamicResource SettingsTextForeground}" Margin="0,4"/>
            <CheckBox x:Name="ChkTaskComplete" Content="Notify on task complete" Foreground="{DynamicResource SettingsTextForeground}" Margin="0,4"/>
            <CheckBox x:Name="ChkPlaySound" Content="Play notification sound" Foreground="{DynamicResource SettingsTextForeground}" Margin="0,4"/>
            <CheckBox x:Name="ChkAutoDismissWhenFocused" Content="Auto-dismiss when terminal is focused" Foreground="{DynamicResource SettingsTextForeground}" Margin="0,4"/>
            <StackPanel Orientation="Horizontal" Margin="20,4,0,4">
                <TextBlock Text="Dismiss after" Foreground="{DynamicResource SettingsTextForeground}" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtAutoDismissSeconds" Width="50" Margin="6,0" VerticalContentAlignment="Center" PreviewTextInput="OnAutoDismissSecondsPreviewTextInput"/>
                <TextBlock Text="seconds (0 = persists)" Foreground="{DynamicResource SettingsTextForeground}" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- Startup section -->
        <TextBlock Grid.Row="6" Text="Startup" Foreground="{DynamicResource SettingsSectionForeground}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="7">
            <CheckBox x:Name="ChkAutoStart" Content="Start with Windows" Foreground="{DynamicResource SettingsTextForeground}" Margin="0,4"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="80" Margin="0,0,8,0" Click="OnSave"
                    Background="{DynamicResource AccentButtonBackground}" Foreground="{DynamicResource AccentButtonForeground}" BorderBrush="{DynamicResource AccentButtonBackground}" Padding="8,6"/>
            <Button Content="Cancel" Width="80" Click="OnCancel"
                    Background="{DynamicResource SettingsButtonBackground}" Foreground="{DynamicResource SettingsButtonForeground}" BorderBrush="{DynamicResource SettingsButtonBorder}" Padding="8,6"/>
        </StackPanel>
    </Grid>
</Window>
